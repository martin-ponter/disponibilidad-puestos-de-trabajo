---
import { buildMonth } from '../utils/fechas';

interface Props {
  fechaSeleccionada: string;
}

const { fechaSeleccionada } = Astro.props;
const mes = buildMonth(new Date());
---

<section class="panel">
  <div class="panel__header">
    <div>
      <p class="eyebrow">Calendario</p>
      <h2>Selecciona una fecha</h2>
    </div>

    <div class="calendar__toolbar">
      <button type="button" class="ghost-button" data-calendar-prev aria-label="Mes anterior">
        &larr;
      </button>
      <strong data-calendar-label>{mes.etiqueta}</strong>
      <button type="button" class="ghost-button" data-calendar-next aria-label="Mes siguiente">
        &rarr;
      </button>
    </div>
  </div>

  <div class="calendar">
    <div class="calendar__weekdays">
      {mes.diasSemana.map((dia) => <span>{dia}</span>)}
    </div>

    <div class="calendar__grid" data-calendar-grid>
      {mes.dias.map((dia) => (
        <button
          type="button"
          class:list={[
            'calendar__day',
            dia.perteneceAlMes ? '' : 'is-muted',
            dia.esHoy ? 'is-today' : '',
            dia.iso === fechaSeleccionada ? 'is-selected' : '',
          ]}
          data-calendar-day={dia.iso}
        >
          <span>{dia.numero}</span>
        </button>
      ))}
    </div>
  </div>
</section>
