---
import Layout from "../layouts/Layout.astro";
import { officeMaps } from "../data/office-maps";
import OfficeMapRenderer from "../components/astro/maps/OfficeMapRenderer.astro";

const map = officeMaps["Toledo::Sala Reuniones Toledo"];

const deskStates = {
  "TOL-23": { available: true },
};
---

<Layout>
  <main class="min-h-screen bg-slate-50 p-6">
    <div class="mx-auto max-w-5xl">
      <h1 class="mb-6 text-2xl font-semibold text-slate-900">
        Toledo · Sala Reuniones Toledo
      </h1>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/70">
        <OfficeMapRenderer
          map={map}
          deskStates={deskStates}
          selectedDeskId="TOL-23"
        />
      </div>
    </div>
  </main>
</Layout>