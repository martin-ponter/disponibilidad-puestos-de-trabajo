---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ComedorReservationHeader from "../components/astro/comedor/ComedorReservationHeader.astro";
import ComedorReservationApp from "../components/react/components/comedor/ComedorReservationApp.jsx";
---

<Layout>
  <main class="min-h-screen bg-slate-50 text-slate-900">
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.06),transparent_28%)]"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <ComedorReservationHeader />

        <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-xl shadow-slate-200/70 sm:p-6">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-slate-900">
              Reserva tu sitio en comedor
            </h2>
            <p class="mt-1 text-sm text-slate-500">
              Selecciona oficina, fecha y tramo horario. Después elige el asiento
              disponible en el plano provisional del comedor.
            </p>
          </div>

          <ComedorReservationApp client:load />
        </section>
      </div>
    </section>
  </main>
</Layout>