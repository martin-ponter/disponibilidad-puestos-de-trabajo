---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ViewDesksReact from "../components/react/components/ver-mesas/VerMesas";

import { officeMaps } from "../data/maps/office-maps";

const officeRooms = Object.values(officeMaps).reduce((acc, map) => {
  if (!acc[map.office]) {
    acc[map.office] = [];
  }

  if (!acc[map.office].includes(map.room)) {
    acc[map.office].push(map.room);
  }

  return acc;
}, {});

const genericOfficeDeskData = {
  Madrid: [
    { id: "M1" },
    { id: "M2" },
    { id: "M3" },
    { id: "M4" },
    { id: "M5" },
    { id: "M6" },
    { id: "M7" },
    { id: "M8" },
  ],
  Consuegra: [
    { id: "C1" },
    { id: "C2" },
    { id: "C3" },
    { id: "C4" },
    { id: "C5" },
    { id: "C6" },
    { id: "C7" },
    { id: "C8" },
  ],
};

const ENTITY_TYPE_ID = 1058;
const FIELD_CENTER = "ufCrm22_1774265887";
const FIELD_ROOM = "ufCrm22_1774266047";
const FIELD_RESOURCE = "ufCrm22_1774266138";
const FIELD_RESOURCE_TYPE = "ufCrm22_1774266164";
const FIELD_DATE = "ufCrm22_1774266223";
const FIELD_START = "ufCrm22_1774266245";
const FIELD_END = "ufCrm22_1774266267";
const FIELD_STATUS = "ufCrm22_1774266293";
const FIELD_NOTES = "ufCrm22_1774266335";
---

<Layout>
  <ViewDesksReact
    client:load
    officeRooms={officeRooms}
    customMaps={officeMaps}
    genericOfficeDeskData={genericOfficeDeskData}
    ENTITY_TYPE_ID={ENTITY_TYPE_ID}
    FIELD_CENTER={FIELD_CENTER}
    FIELD_ROOM={FIELD_ROOM}
    FIELD_RESOURCE={FIELD_RESOURCE}
    FIELD_RESOURCE_TYPE={FIELD_RESOURCE_TYPE}
    FIELD_DATE={FIELD_DATE}
    FIELD_START={FIELD_START}
    FIELD_END={FIELD_END}
    FIELD_STATUS={FIELD_STATUS}
    FIELD_NOTES={FIELD_NOTES}
  />
</Layout>
