---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import Cards from "../components/react/components/compañeros/Cards";
---

<Layout>
  <main class="min-h-screen bg-slate-50 text-slate-900">
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.06),transparent_28%)]"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="flex flex-row-reverse justify-between py-5">
          <div class="mb-8 flex h-min justify-between gap-4">
            <a
              href="/"
              class="inline-flex gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-100"
            >
              <span>←</span>
              Volver
            </a>
          </div>

          <div class="mb-8">
            <h1
              class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl"
            >
              Disponibilidad del equipo
            </h1>

            <p
              class="mt-4 max-w-3xl text-sm leading-7 text-slate-600 sm:text-base"
            >
              Consulta rápidamente quién está disponible para trabajar en una
              fecha y hora concretas, en qué oficina se encuentra, si está en
              teletrabajo o si no trabaja.
            </p>
          </div>
        </div>
        <Cards client:load />
      </div>
    </section>
  </main>
</Layout>
